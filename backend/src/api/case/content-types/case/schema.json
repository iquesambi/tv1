{
  "kind": "collectionType",
  "collectionName": "cases",
  "info": {
    "singularName": "case",
    "pluralName": "cases",
    "displayName": "Case"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "Data": {
      "type": "date"
    },
    "descricao": {
      "type": "text"
    },
    "imagem_capa": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "cliente": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cliente.cliente",
      "inversedBy": "cases"
    },
    "agencia": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::agencia.agencia",
      "inversedBy": "cases"
    },
    "blocos": {
      "type": "dynamiczone",
      "components": [
        "blocks.subtitulo",
        "blocks.texto",
        "blocks.imagem-simples",
        "blocks.galeria",
        "blocks.imagem-trio",
        "blocks.video",
        "blocks.big-numbers"
      ]
    }
  }
}
