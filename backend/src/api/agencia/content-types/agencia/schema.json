{
  "kind": "collectionType",
  "collectionName": "agencias",
  "info": {
    "singularName": "agencia",
    "pluralName": "agencias",
    "displayName": "Agência / Marca"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Nome": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "uid",
      "required": true
    },
    "Logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "url_externa": {
      "type": "string"
    },
    "posicao": {
      "type": "integer",
      "default": 1,
      "min": 1
    },
    "cases": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::case.case",
      "mappedBy": "agencia"
    }
  }
}
