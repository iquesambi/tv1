{
  "kind": "collectionType",
  "collectionName": "agencias",
  "info": {
    "singularName": "agencia",
    "pluralName": "agencias",
    "displayName": "Agência / Marca"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "url_externo": {
      "type": "string"
    },
    "ordem": {
      "type": "integer",
      "default": 0
    },
    "cases": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::case.case",
      "mappedBy": "agencia"
    }
  }
}
